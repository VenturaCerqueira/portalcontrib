# Backend Environment Variables Template
# Copy to .env and fill your values!

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password

# AWS S3 (Required for photo uploads)
AWS_ACCESS_KEY_ID=AKIA...your_access_key_from_AWS_IAM
AWS_SECRET_ACCESS_KEY=abcd...your_secret_key_from_AWS_IAM
AWS_BUCKET=your-s3-bucket-name
AWS_REGION=sa-east-1

# App
PORT=3001
NODE_ENV=development

# Get AWS keys: AWS Console > IAM > Users > Security credentials > Access keys
# Create bucket: S3 > Create bucket (enable public ACL for photos)
